# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# legacy static site
/_legacy

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Netlify folder
.netlify

# Auto-generated by Netlify CLI during `netlify dev` (not a Deno app)
deno.lock

# Supabase edge deploy bundles (generated by scripts/build-edge-deploy.mjs)
.edge-deploy/
supabase/.temp/

# Cursor agent skills (local IDE tooling, not part of the app)
.agents/
skills-lock.json

# Firebase CLI local state (auth cache, deploy logs — not the app)
.firebase/
firebase-debug.log
.firebaserc.local

# One-off local audit scratch (not shipped with the product)
fixtures/nce/audit-report.json
scripts/audit-nce-cell-report.py
scripts/audit-run-mapper.ts
node_modules/
.next/
dist/*
!dist/manifest.json
!dist/*.dmg
.cache/
__pycache__/
*.pyc
firebase-debug.log

# Python
__pycache__/
*.pyc
nce_converter/
